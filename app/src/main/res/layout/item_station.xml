<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    android:layout_margin="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Charger Image -->
        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/placeholder_home_a"
            android:src="@android:drawable/ic_menu_compass"
            android:scaleType="centerCrop" />

        <!-- Charger Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/charger_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_home_a"
                android:textStyle="bold"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/charger_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_distance"
                android:layout_marginTop="4dp"
                android:textColor="#666"/>

            <TextView
                android:id="@+id/charger_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_price"
                android:layout_marginTop="8dp"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
